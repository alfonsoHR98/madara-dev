---
import OSLayout from "../layouts/OSLayout.astro";
import Desktop from "../components/shell/Desktop.astro";
import Taskbar from "../components/shell/Taskbar.astro";
import WindowFrame from "../components/windows/WindowFrame.astro";
import AboutApp from "../components/apps/AboutApp.astro";
import ProjectsApp from "../components/apps/ProjectsApp.astro";
import ContactApp from "../components/apps/ContactApp.astro";
import DesktopIcons from "../components/shell/DesktopIcons.astro";
import Wallpaper from "../components/shell/Wallpaper.astro";
import StartMenu from "../components/shell/StartMenu.astro";
---

<OSLayout title="Madara Os">
    <Wallpaper />
    <Desktop>
        <DesktopIcons />
        <WindowFrame title="Sobre mí" id="window-about">
            <AboutApp />
        </WindowFrame>
        <WindowFrame title="Proyectos" id="window-projects">
            <ProjectsApp />
        </WindowFrame>
        <WindowFrame title="Contacto" id="window-contact">
            <ContactApp />
        </WindowFrame>
    </Desktop>

    <StartMenu />
    <Taskbar />

    <script>
        const buttons = document.querySelectorAll<HTMLButtonElement>(
            ".taskbar-app[data-target]",
        );
        const desktopIcons = document.querySelectorAll<HTMLButtonElement>(
            ".desktop-icon[data-target]",
        );
        const windows = document.querySelectorAll<HTMLElement>(".window");

        let topZ = 10;

        windows.forEach((w, i) => {
            w.style.top = `${2 + i * 2}rem`;
            w.style.left = `${2 + i * 2}rem`;
        });

        function bringToFront(win: HTMLElement) {
            topZ++;
            win.style.zIndex = String(topZ);
        }

        function getTaskbarBtn(targetId: string) {
            return document.querySelector<HTMLElement>(
                `.taskbar-app[data-target="${targetId}"]`,
            );
        }

        function minimizeWindow(win: HTMLElement) {
            const btn = getTaskbarBtn(win.id);
            if (!btn) return;

            const btnRect = btn.getBoundingClientRect();
            const winRect = win.getBoundingClientRect();
            const dx =
                btnRect.left + btnRect.width / 2 -
                (winRect.left + winRect.width / 2);
            const dy =
                btnRect.top + btnRect.height / 2 -
                (winRect.top + winRect.height / 2);

            win.style.transition =
                "transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease";
            win.style.transform = `translate(${dx}px, ${dy}px) scale(0.15)`;
            win.style.opacity = "0";
            win.style.pointerEvents = "none";
            btn.classList.remove("active");

            setTimeout(() => {
                win.classList.remove("active");
                win.style.transform = "";
                win.style.transition = "";
            }, 350);
        }

        function activate(targetId: string) {
            const target = document.getElementById(targetId) as HTMLElement;
            if (!target) return;

            if (target.classList.contains("active")) {
                minimizeWindow(target);
                return;
            }

            target.classList.add("active");
            target.style.opacity = "1";
            target.style.pointerEvents = "auto";
            bringToFront(target);

            buttons.forEach((b) => {
                if (b.dataset.target === targetId) b.classList.add("active");
            });
        }

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                if (btn.dataset.target) activate(btn.dataset.target);
            });
        });

        // Start Menu
        const startBtn = document.getElementById("start-btn");
        const startMenu = document.getElementById("start-menu");

        startBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            startMenu?.classList.toggle("open");
        });

        document.addEventListener("click", (e) => {
            if (!startMenu?.contains(e.target as Node)) {
                startMenu?.classList.remove("open");
            }
        });

        const startAppBtns = document.querySelectorAll<HTMLButtonElement>(".start-app-item[data-target]");
        startAppBtns.forEach(btn => {
            btn.addEventListener("click", () => {
                if (btn.dataset.target) activate(btn.dataset.target);
                startMenu?.classList.remove("open");
            });
        });

        desktopIcons.forEach((icon) => {
            icon.addEventListener("click", () => {
                if (icon.dataset.target) activate(icon.dataset.target);
            });
        });

        const aboutBtns = document.querySelectorAll<HTMLButtonElement>(".app-actions button[data-target]");
        aboutBtns.forEach(btn => {
            btn.addEventListener("click", () => {
                if (btn.dataset.target) activate(btn.dataset.target);
            });
        });

        windows.forEach((win) => {
            const closeBtn = win.querySelector<HTMLElement>('[aria-label="Cerrar"]');
            const minimizeBtn = win.querySelector<HTMLElement>('[aria-label="Minimizar"]');
            const maximizeBtn = win.querySelector<HTMLElement>('[aria-label="Maximizar"]');
            const titlebar = win.querySelector<HTMLElement>(".window-titlebar");

            let maximized = false;
            let prevStyles = { top: "", left: "", width: "", height: "" };
            let dragging = false;
            let startX = 0, startY = 0, startLeft = 0, startTop = 0;

            closeBtn?.addEventListener("click", () => {
                win.classList.remove("active");
                win.style.opacity = "0";
                win.style.pointerEvents = "none";
                getTaskbarBtn(win.id)?.classList.remove("active");
            });

            minimizeBtn?.addEventListener("click", () => minimizeWindow(win));

            maximizeBtn?.addEventListener("click", () => {
                if (!maximized) {
                    prevStyles = {
                        top: win.style.top,
                        left: win.style.left,
                        width: win.style.width,
                        height: win.style.height,
                    };
                    win.style.transition =
                        "top 0.25s ease, left 0.25s ease, width 0.25s ease, height 0.25s ease";
                    win.style.top = "0";
                    win.style.left = "0";
                    win.style.width = "100%";
                    win.style.height = "calc(100vh - 3.5rem)";
                    win.style.borderRadius = "0";
                    maximized = true;
                } else {
                    win.style.top = prevStyles.top || "2rem";
                    win.style.left = prevStyles.left || "2rem";
                    win.style.width = "";
                    win.style.height = "";
                    win.style.borderRadius = "";
                    maximized = false;
                    setTimeout(() => { win.style.transition = ""; }, 250);
                }
            });

            titlebar?.addEventListener("mousedown", (e) => {
                if (maximized) return;
                dragging = true;
                startX = e.clientX;
                startY = e.clientY;
                startLeft = win.offsetLeft;
                startTop = win.offsetTop;
                bringToFront(win);
                e.preventDefault();
            });

            document.addEventListener("mousemove", (e) => {
                if (!dragging) return;
                win.style.left = `${startLeft + (e.clientX - startX)}px`;
                win.style.top = `${startTop + (e.clientY - startY)}px`;
            });

            document.addEventListener("mouseup", () => { dragging = false; });

            win.addEventListener("mousedown", () => bringToFront(win));
        });
    </script>
</OSLayout>
