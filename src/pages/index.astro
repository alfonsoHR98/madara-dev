---
import OSLayout from "../layouts/OSLayout.astro";
import Desktop from "../components/shell/Desktop.astro";
import Taskbar from "../components/shell/Taskbar.astro";
import WindowFrame from "../components/windows/WindowFrame.astro";
import AboutApp from "../components/apps/AboutApp.astro";
import ProjectsApp from "../components/apps/ProjectsApp.astro";
import ContactApp from "../components/apps/ContactApp.astro";
import TerminalApp from "../components/apps/TerminalApp.astro";
import DesktopIcons from "../components/shell/DesktopIcons.astro";
import Wallpaper from "../components/shell/Wallpaper.astro";
import StartMenu from "../components/shell/StartMenu.astro";
---

<OSLayout title="Madara Os">
    <Wallpaper />
    <Desktop>
        <DesktopIcons />
        <WindowFrame title="Sobre mí" id="window-about">
            <AboutApp />
        </WindowFrame>
        <WindowFrame title="Proyectos" id="window-projects">
            <ProjectsApp />
        </WindowFrame>
        <WindowFrame title="Contacto" id="window-contact">
            <ContactApp />
        </WindowFrame>
        <WindowFrame title="Terminal" id="window-terminal">
            <TerminalApp />
        </WindowFrame>
    </Desktop>

    <StartMenu />
    <Taskbar />

    <script>
        const windows = document.querySelectorAll<HTMLElement>(".window");
        const taskbarRunning = document.getElementById("taskbar-running");

        let topZ = 10;

        const APP_META: Record<string, { label: string; icon: string }> = {
            "window-about": {
                label: "Sobre mí",
                icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
            },
            "window-projects": {
                label: "Proyectos",
                icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`,
            },
            "window-contact": {
                label: "Contacto",
                icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
            },
            "window-terminal": {
                label: "Terminal",
                icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
            },
        };

        windows.forEach((w, i) => {
            w.style.top = `${2 + i * 2}rem`;
            w.style.left = `${2 + i * 2}rem`;
        });

        function setFocused(targetId: string) {
            document.querySelectorAll<HTMLElement>(".taskbar-app").forEach(b => b.classList.remove("focused"));
            const btn = document.querySelector<HTMLElement>(
                `.taskbar-pinned [data-target="${targetId}"], #taskbar-running [data-target="${targetId}"]`
            );
            btn?.classList.add("focused");
        }

        function bringToFront(win: HTMLElement) {
            topZ++;
            win.style.zIndex = String(topZ);
            setFocused(win.id);
        }

        const PINNED = ["window-terminal"];

        function addToTaskbar(id: string) {
            if (PINNED.includes(id)) return;
            if (document.getElementById(`tb-${id}`)) return;
            const meta = APP_META[id];
            if (!meta) return;

            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "taskbar-app active";
            btn.id = `tb-${id}`;
            btn.dataset.target = id;
            btn.title = meta.label;
            btn.innerHTML = `${meta.icon}<span class="taskbar-app-dot"></span>`;
            btn.addEventListener("click", () => activate(id));
            taskbarRunning?.appendChild(btn);
        }

        function removeFromTaskbar(id: string) {
            document.getElementById(`tb-${id}`)?.remove();
        }

        function getAnyTaskbarBtn(targetId: string) {
            return document.querySelector<HTMLElement>(
                `.taskbar-pinned [data-target="${targetId}"], #taskbar-running [data-target="${targetId}"]`
            );
        }

        function minimizeWindow(win: HTMLElement) {
            const btn = getAnyTaskbarBtn(win.id);
            if (!btn) return;

            const btnRect = btn.getBoundingClientRect();
            const winRect = win.getBoundingClientRect();
            const dx = btnRect.left + btnRect.width / 2 - (winRect.left + winRect.width / 2);
            const dy = btnRect.top + btnRect.height / 2 - (winRect.top + winRect.height / 2);

            win.style.transition = "transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease";
            win.style.transform = `translate(${dx}px, ${dy}px) scale(0.15)`;
            win.style.opacity = "0";
            win.style.pointerEvents = "none";

            document.getElementById(`tb-${win.id}`)?.classList.remove("active");
            document.querySelector<HTMLElement>(`.taskbar-pinned [data-target="${win.id}"]`)?.classList.remove("active");

            setTimeout(() => {
                win.classList.remove("active");
                win.style.transform = "";
                win.style.transition = "";
            }, 350);
        }

        function activate(targetId: string) {
            const target = document.getElementById(targetId) as HTMLElement;
            if (!target) return;

            if (target.classList.contains("active")) {
                minimizeWindow(target);
                return;
            }

            target.classList.add("active");
            target.style.opacity = "1";
            target.style.pointerEvents = "auto";
            bringToFront(target);
            addToTaskbar(targetId);

            document.querySelectorAll<HTMLElement>(".taskbar-running .taskbar-app").forEach(b => {
                b.classList.toggle("active", b.dataset.target === targetId);
            });

            const pinnedBtn = document.querySelector<HTMLElement>(`.taskbar-pinned [data-target="${targetId}"]`);
            if (pinnedBtn) {
                document.querySelectorAll<HTMLElement>(".taskbar-pinned .taskbar-app").forEach(b => b.classList.remove("active"));
                pinnedBtn.classList.add("active");
            }
        }

        // Taskbar pinned
        document.querySelectorAll<HTMLButtonElement>(".taskbar-pinned [data-target]").forEach(btn => {
            btn.addEventListener("click", () => {
                if (btn.dataset.target) activate(btn.dataset.target);
            });
        });

        // Desktop icons
        document.querySelectorAll<HTMLButtonElement>(".desktop-icon[data-target]").forEach(icon => {
            icon.addEventListener("click", () => {
                if (icon.dataset.target) activate(icon.dataset.target);
            });
        });

        // About app buttons
        document.querySelectorAll<HTMLButtonElement>(".app-actions button[data-target]").forEach(btn => {
            btn.addEventListener("click", () => {
                if (btn.dataset.target) activate(btn.dataset.target);
            });
        });

        // Start menu apps
        document.querySelectorAll<HTMLButtonElement>(".start-app-item[data-target]").forEach(btn => {
            btn.addEventListener("click", () => {
                if (btn.dataset.target) activate(btn.dataset.target);
                document.getElementById("start-menu")?.classList.remove("open");
            });
        });

        // Start menu toggle
        const startBtn = document.getElementById("start-btn");
        const startMenu = document.getElementById("start-menu");
        startBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            startMenu?.classList.toggle("open");
        });
        document.addEventListener("click", (e) => {
            if (!startMenu?.contains(e.target as Node)) {
                startMenu?.classList.remove("open");
            }
        });

        // Window controls + drag
        windows.forEach((win) => {
            const closeBtn = win.querySelector<HTMLElement>('[aria-label="Cerrar"]');
            const minimizeBtn = win.querySelector<HTMLElement>('[aria-label="Minimizar"]');
            const maximizeBtn = win.querySelector<HTMLElement>('[aria-label="Maximizar"]');
            const titlebar = win.querySelector<HTMLElement>(".window-titlebar");

            let maximized = false;
            let prevStyles = { top: "", left: "", width: "", height: "" };
            let dragging = false;
            let startX = 0, startY = 0, startLeft = 0, startTop = 0;

            closeBtn?.addEventListener("click", () => {
                win.classList.remove("active");
                win.style.opacity = "0";
                win.style.pointerEvents = "none";
                removeFromTaskbar(win.id);
                document.querySelector<HTMLElement>(`.taskbar-pinned [data-target="${win.id}"]`)?.classList.remove("active");
            });

            minimizeBtn?.addEventListener("click", () => minimizeWindow(win));

            maximizeBtn?.addEventListener("click", () => {
                if (!maximized) {
                    prevStyles = { top: win.style.top, left: win.style.left, width: win.style.width, height: win.style.height };
                    win.style.transition = "top 0.25s ease, left 0.25s ease, width 0.25s ease, height 0.25s ease";
                    win.style.top = "0";
                    win.style.left = "0";
                    win.style.width = "100%";
                    win.style.height = "calc(100vh - 3.5rem)";
                    win.style.borderRadius = "0";
                    maximized = true;
                } else {
                    win.style.top = prevStyles.top || "2rem";
                    win.style.left = prevStyles.left || "2rem";
                    win.style.width = "";
                    win.style.height = "";
                    win.style.borderRadius = "";
                    maximized = false;
                    setTimeout(() => { win.style.transition = ""; }, 250);
                }
            });

            titlebar?.addEventListener("mousedown", (e) => {
                if (maximized) return;
                dragging = true;
                startX = e.clientX;
                startY = e.clientY;
                startLeft = win.offsetLeft;
                startTop = win.offsetTop;
                bringToFront(win);
                e.preventDefault();
            });

            document.addEventListener("mousemove", (e) => {
                if (!dragging) return;
                win.style.left = `${startLeft + (e.clientX - startX)}px`;
                win.style.top = `${startTop + (e.clientY - startY)}px`;
            });

            document.addEventListener("mouseup", () => { dragging = false; });
            win.addEventListener("mousedown", () => bringToFront(win));
        });
    </script>
</OSLayout>
