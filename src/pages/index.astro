---
export const prerender = true;

import OSLayout from "../layouts/OSLayout.astro";
import Desktop from "../components/shell/Desktop.astro";
import Taskbar from "../components/shell/Taskbar.astro";
import Menubar from "../components/shell/Menubar.astro";
import WindowFrame from "../components/windows/WindowFrame.astro";
import AboutApp from "../components/apps/AboutApp.astro";
import ProjectsApp from "../components/apps/ProjectsApp.astro";
import ContactApp from "../components/apps/ContactApp.astro";
import TerminalApp from "../components/apps/TerminalApp.astro";
import BrowserApp from "../components/apps/BrowserApp.astro";
import SnakeApp from "../components/apps/SnakeApp.astro";
import DesktopIcons from "../components/shell/DesktopIcons.astro";
import Wallpaper from "../components/shell/Wallpaper.astro";
import StartMenu from "../components/shell/StartMenu.astro";
---

<OSLayout title="Alfonso Hernández | Full Stack Developer">
    <h1 class="sr-only">Alfonso Hernández — Full Stack Developer | MadaraOS</h1>
    <Wallpaper />
    <Menubar />
    <Desktop>
        <DesktopIcons />
        <WindowFrame title="Sobre mí" id="window-about">
            <AboutApp />
        </WindowFrame>
        <WindowFrame title="Proyectos" id="window-projects">
            <ProjectsApp />
        </WindowFrame>
        <WindowFrame title="Contacto" id="window-contact">
            <ContactApp />
        </WindowFrame>
        <WindowFrame title="Navegador" id="window-browser">
            <BrowserApp />
        </WindowFrame>
        <WindowFrame title="Terminal" id="window-terminal">
            <TerminalApp />
        </WindowFrame>
        <WindowFrame title="Snake" id="window-snake">
            <SnakeApp />
        </WindowFrame>
    </Desktop>

    <StartMenu />
    <Taskbar />

    <script>
        const windows = document.querySelectorAll<HTMLElement>(".window");
        const dock = document.getElementById("dock");
        const QUICK_APPS = ["window-about", "window-projects", "window-contact", "window-browser", "window-terminal", "window-snake"];

        let topZ = 10;
        let focusedWindowId = "";

        const APP_META: Record<string, { label: string; icon: string; bg: string }> = {
            "window-about": {
                label: "Sobre mí",
                bg: "linear-gradient(145deg,#5e5ce6,#3a38b0)",
                icon: `<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
            },
            "window-projects": {
                label: "Proyectos",
                bg: "linear-gradient(145deg,#30d158,#1a8f38)",
                icon: `<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`,
            },
            "window-contact": {
                label: "Contacto",
                bg: "linear-gradient(145deg,#0a84ff,#0060cc)",
                icon: `<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
            },
            "window-browser": {
                label: "Navegador",
                bg: "linear-gradient(145deg,#5ac8fa,#0066d6)",
                icon: `<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
            },
            "window-terminal": {
                label: "Terminal",
                bg: "linear-gradient(145deg,#1c1c1e,#2c2c2e)",
                icon: `<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
            },
            "window-snake": {
                label: "Snake",
                bg: "linear-gradient(145deg,#1a4a2e,#3ecf8e)",
                icon: `<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8"><path d="M12 2a3 3 0 0 1 3 3v1a3 3 0 0 1-3 3H9a3 3 0 0 0-3 3v1a3 3 0 0 0 3 3h3a3 3 0 0 1 3 3v1a3 3 0 0 1-3 3"/><circle cx="18" cy="4" r="1.5" fill="white" stroke="none"/></svg>`,
            },
        };

        windows.forEach((w, i) => {
            w.style.top = `${3 + i * 2}rem`;
            w.style.left = `${3 + i * 2}rem`;
        });

        const PINNED_APPS = ["window-terminal"];

        // Dock inicial: apps pineadas + terminal abierta al final de la secuencia de arranque
        PINNED_APPS.forEach(addToDock);
        const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
        const bootSkipped = document.documentElement.classList.contains("boot-skip");
        const terminalDelay = reduceMotion ? 0 : bootSkipped ? 850 : 2300;
        setTimeout(() => activate("window-terminal"), terminalDelay);

        // ── Dock item management ──
        function addToDock(id: string) {
            if (document.getElementById(`dock-${id}`)) return;
            const meta = APP_META[id];
            if (!meta) return;

            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "dock-item";
            btn.id = `dock-${id}`;
            btn.dataset.target = id;
            btn.dataset.label = meta.label;
            btn.setAttribute("aria-label", `Abrir ${meta.label}`);
            btn.innerHTML = `
                <div class="dock-icon" style="background:${meta.bg}">${meta.icon}</div>
            `;
            btn.addEventListener("click", () => activate(id));
            dock?.appendChild(btn);
        }

        function removeFromDock(id: string) {
            if (PINNED_APPS.includes(id)) return;
            document.getElementById(`dock-${id}`)?.remove();
        }

        function syncDockState(focusedId?: string) {
            document.querySelectorAll<HTMLElement>(".dock-item").forEach(btn => {
                const targetId = btn.dataset.target;
                if (!targetId) return;
                const win = document.getElementById(targetId);
                btn.classList.toggle("active", !!win?.classList.contains("active"));
                btn.classList.toggle("focused", !!focusedId && focusedId === targetId);
            });
        }

        function getDockBtn(targetId: string) {
            return document.querySelector<HTMLElement>(`#dock [data-target="${targetId}"]`);
        }

        // ── Focus state ──
        const menubarApp = document.getElementById("menubar-app");
        function setFocused(targetId: string) {
            focusedWindowId = targetId;
            syncDockState(targetId);
            if (menubarApp) menubarApp.textContent = APP_META[targetId]?.label ?? "";
        }

        function bringToFront(win: HTMLElement) {
            topZ++;
            win.style.zIndex = String(topZ);
            setFocused(win.id);
        }

        function getFocusedWindow() {
            return focusedWindowId ? document.getElementById(focusedWindowId) as HTMLElement | null : null;
        }

        function closeWindow(win: HTMLElement) {
            win.style.transition = "opacity 0.2s ease, transform 0.2s ease";
            win.style.opacity = "0";
            win.style.transform = "scale(0.95)";
            setTimeout(() => {
                win.classList.remove("active");
                win.setAttribute("aria-hidden", "true");
                win.style.transform = "";
                win.style.transition = "";
                win.style.pointerEvents = "none";
                removeFromDock(win.id);
                syncDockState();
            }, 200);
        }

        function snapWindow(win: HTMLElement, side: "left" | "right") {
            win.classList.add("active");
            win.setAttribute("aria-hidden", "false");
            win.style.opacity = "1";
            win.style.pointerEvents = "auto";
            win.style.transition = "top 0.2s ease, left 0.2s ease, width 0.2s ease, height 0.2s ease";
            win.style.top = "1.75rem";
            win.style.left = side === "left" ? "0" : "50%";
            win.style.width = "50%";
            win.style.height = "calc(100vh - 1.75rem)";
            win.style.borderRadius = "0";
            bringToFront(win);
            addToDock(win.id);
            setTimeout(() => { win.style.transition = ""; }, 220);
        }

        // ── Minimize ──
        function minimizeWindow(win: HTMLElement) {
            const btn = getDockBtn(win.id);
            if (!btn) return;

            const btnRect = btn.getBoundingClientRect();
            const winRect = win.getBoundingClientRect();
            const dx = btnRect.left + btnRect.width / 2 - (winRect.left + winRect.width / 2);
            const dy = btnRect.top + btnRect.height / 2 - (winRect.top + winRect.height / 2);

            win.style.transition = "transform 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.35s ease";
            win.style.transform = `translate(${dx}px,${dy}px) scale(0.12)`;
            win.style.opacity = "0";
            win.style.pointerEvents = "none";

            btn.classList.remove("focused");

            setTimeout(() => {
                win.classList.remove("active");
                win.setAttribute("aria-hidden", "true");
                win.style.transform = "";
                win.style.transition = "";
                syncDockState();
            }, 350);
        }

        // ── Activate ──
        function activate(targetId: string) {
            const target = document.getElementById(targetId) as HTMLElement;
            if (!target) return;

            if (target.classList.contains("active")) {
                minimizeWindow(target);
                return;
            }

            target.classList.add("active");
            target.setAttribute("aria-hidden", "false");
            target.style.opacity = "1";
            target.style.pointerEvents = "auto";
            bringToFront(target);
            addToDock(targetId);
            syncDockState(targetId);

            const dockBtn = getDockBtn(targetId);
            if (dockBtn && !dockBtn.classList.contains("bouncing")) {
                dockBtn.classList.add("bouncing");
                dockBtn.addEventListener("animationend", () => dockBtn.classList.remove("bouncing"), { once: true });
            }
        }

        document.addEventListener("madara:open-app", (event) => {
            const id = (event as CustomEvent<{ id?: string }>).detail?.id;
            if (id) activate(id);
        });

        // ── Desktop icons ──
        document.querySelectorAll<HTMLButtonElement>(".desktop-icon[data-target]").forEach(icon => {
            icon.addEventListener("click", () => {
                if (icon.dataset.target) activate(icon.dataset.target);
            });
        });

        // ── About app action buttons ──
        document.querySelectorAll<HTMLButtonElement>(".app-actions button[data-target]").forEach(btn => {
            btn.addEventListener("click", () => {
                if (btn.dataset.target) activate(btn.dataset.target);
            });
        });

        // ── Start menu apps ──
        document.querySelectorAll<HTMLButtonElement>(".start-app-item[data-target]").forEach(btn => {
            btn.addEventListener("click", () => {
                if (btn.dataset.target) activate(btn.dataset.target);
                closeStartMenu();
            });
        });

        // ── Start menu toggle ──
        const startBtn = document.getElementById("start-btn");
        const startMenu = document.getElementById("start-menu");
        function setStartMenuOpen(open: boolean) {
            startMenu?.classList.toggle("open", open);
            startMenu?.setAttribute("aria-hidden", String(!open));
            startBtn?.setAttribute("aria-expanded", String(open));
        }
        function closeStartMenu() {
            setStartMenuOpen(false);
        }
        startBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            setStartMenuOpen(!startMenu?.classList.contains("open"));
        });
        document.addEventListener("click", (e) => {
            if (!startMenu?.contains(e.target as Node)) {
                closeStartMenu();
            }
        });
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
                closeStartMenu();
            }

            const target = e.target as HTMLElement;
            const isTyping = ["INPUT", "TEXTAREA"].includes(target.tagName) || target.isContentEditable;
            const mod = e.metaKey || e.ctrlKey;
            if (!mod || isTyping) return;

            if (e.key.toLowerCase() === "k") {
                e.preventDefault();
                setStartMenuOpen(!startMenu?.classList.contains("open"));
                return;
            }

            const quickIndex = Number(e.key) - 1;
            if (quickIndex >= 0 && quickIndex < QUICK_APPS.length) {
                e.preventDefault();
                activate(QUICK_APPS[quickIndex]);
                return;
            }

            const focused = getFocusedWindow();
            if (!focused) return;

            if (e.key.toLowerCase() === "m") {
                e.preventDefault();
                minimizeWindow(focused);
            } else if (e.key.toLowerCase() === "w") {
                e.preventDefault();
                closeWindow(focused);
            } else if (e.key === "ArrowLeft") {
                e.preventDefault();
                snapWindow(focused, "left");
            } else if (e.key === "ArrowRight") {
                e.preventDefault();
                snapWindow(focused, "right");
            }
        });

        // ── Dock: gaussian wave magnification ──
        const DOCK_MAX_BOOST = 0.6;   // max extra scale = 1.6x
        const DOCK_SIGMA = 65;        // width of the gaussian bell curve

        dock?.addEventListener("mousemove", (e: MouseEvent) => {
            const items = dock.querySelectorAll<HTMLElement>(".dock-item");
            items.forEach(item => {
                const icon = item.querySelector<HTMLElement>(".dock-icon");
                if (!icon) return;
                const rect = icon.getBoundingClientRect();
                const center = rect.left + rect.width / 2;
                const dist = Math.abs(e.clientX - center);
                const scale = 1 + DOCK_MAX_BOOST * Math.exp(-(dist * dist) / (2 * DOCK_SIGMA * DOCK_SIGMA));
                item.style.setProperty("--dock-scale", scale.toFixed(4));
            });
        });

        dock?.addEventListener("mouseleave", () => {
            dock?.querySelectorAll<HTMLElement>(".dock-item").forEach(item => {
                item.style.setProperty("--dock-scale", "1");
            });
        });

        // Dock siempre visible (estilo macOS)
        dock?.classList.add("dock-visible");

        // ── Window controls + drag ──
        windows.forEach((win) => {
            const closeBtn = win.querySelector<HTMLElement>('[aria-label="Cerrar"]');
            const minimizeBtn = win.querySelector<HTMLElement>('[aria-label="Minimizar"]');
            const maximizeBtn = win.querySelector<HTMLElement>('[aria-label="Maximizar"]');
            const titlebar = win.querySelector<HTMLElement>(".window-titlebar");

            let maximized = false;
            let prevStyles = { top: "", left: "", width: "", height: "" };
            let dragging = false;
            let resizing = false;
            let startX = 0, startY = 0, startLeft = 0, startTop = 0;
            let startWidth = 0, startHeight = 0;
            const resizeHandle = win.querySelector<HTMLElement>(".window-resize-handle");

            closeBtn?.addEventListener("click", () => {
                closeWindow(win);
            });

            minimizeBtn?.addEventListener("click", () => minimizeWindow(win));

            maximizeBtn?.addEventListener("click", () => {
                if (!maximized) {
                    prevStyles = { top: win.style.top, left: win.style.left, width: win.style.width, height: win.style.height };
                    win.style.transition = "top 0.25s ease, left 0.25s ease, width 0.25s ease, height 0.25s ease";
                    win.style.top = "1.75rem";
                    win.style.left = "0";
                    win.style.width = "100%";
                    win.style.height = "calc(100vh - 1.75rem)";
                    win.style.borderRadius = "0";
                    maximized = true;
                } else {
                    win.style.top = prevStyles.top || "3rem";
                    win.style.left = prevStyles.left || "3rem";
                    win.style.width = "";
                    win.style.height = "";
                    win.style.borderRadius = "";
                    maximized = false;
                    setTimeout(() => { win.style.transition = ""; }, 250);
                }
            });

            titlebar?.addEventListener("mousedown", (e) => {
                if (maximized) return;
                dragging = true;
                startX = e.clientX;
                startY = e.clientY;
                startLeft = win.offsetLeft;
                startTop = win.offsetTop;
                bringToFront(win);
                e.preventDefault();
            });

            resizeHandle?.addEventListener("mousedown", (e) => {
                if (maximized) return;
                resizing = true;
                startX = e.clientX;
                startY = e.clientY;
                startWidth = win.offsetWidth;
                startHeight = win.offsetHeight;
                bringToFront(win);
                e.preventDefault();
                e.stopPropagation();
            });

            document.addEventListener("mousemove", (e) => {
                if (dragging) {
                    const newTop = startTop + (e.clientY - startY);
                    win.style.left = `${startLeft + (e.clientX - startX)}px`;
                    win.style.top = `${Math.max(1.75 * 16, newTop)}px`;
                    return;
                }

                if (resizing) {
                    const maxWidth = window.innerWidth - win.offsetLeft - 12;
                    const maxHeight = window.innerHeight - win.offsetTop - 12;
                    const nextWidth = Math.min(maxWidth, Math.max(360, startWidth + e.clientX - startX));
                    const nextHeight = Math.min(maxHeight, Math.max(300, startHeight + e.clientY - startY));
                    win.style.width = `${nextWidth}px`;
                    win.style.height = `${nextHeight}px`;
                }
            });

            document.addEventListener("mouseup", () => { dragging = false; resizing = false; });
            win.addEventListener("mousedown", () => bringToFront(win));
        });
    </script>
</OSLayout>
