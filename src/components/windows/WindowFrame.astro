---
interface Props {
    title: string;
    id: string;
}
const { title, id } = Astro.props;
---

<article class="window" id={id} aria-label={title}>
    <header class="window-titlebar">
        <div class="window-controls">
            <button type="button" class="btn-close" aria-label="Cerrar"></button>
            <button type="button" class="btn-minimize" aria-label="Minimizar"></button>
            <button type="button" class="btn-maximize" aria-label="Maximizar"></button>
        </div>
        <div class="window-title">{title}</div>
    </header>
    <div class="window-content">
        <slot />
    </div>
</article>
