---
import { User, FolderKanban, Mail, SquareTerminal, Globe, Gamepad2 } from "@lucide/astro";

const icons = [
    { id: "window-about",    label: "Sobre mí",  Icon: User },
    { id: "window-projects", label: "Proyectos", Icon: FolderKanban },
    { id: "window-contact",  label: "Contacto",  Icon: Mail },
    { id: "window-browser",  label: "Navegador", Icon: Globe },
    { id: "window-terminal", label: "Terminal",  Icon: SquareTerminal },
    { id: "window-snake",    label: "Snake",     Icon: Gamepad2 },
];
---

<div class="desktop-icons">
    {icons.map(({ id, label, Icon }, index) => (
        <button class="desktop-icon" data-target={id} type="button" style={`--i: ${index}`}>
            <Icon size={36} />
            <span>{label}</span>
        </button>
    ))}
</div>
