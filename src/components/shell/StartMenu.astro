---
import { User, FolderKanban, Mail, SquareTerminal, Search, Power } from "@lucide/astro";
---

<div class="start-menu" id="start-menu" aria-hidden="true">
    <div class="start-search">
        <Search size={15} />
        <input type="text" placeholder="Buscar aplicaciones..." />
    </div>

    <div class="start-section">
        <p class="start-section-label">Ancladas</p>
        <div class="start-apps">
            <button class="start-app-item" data-target="window-about">
                <div class="start-app-icon">
                    <User size={22} />
                </div>
                <span>Sobre mí</span>
            </button>
            <button class="start-app-item" data-target="window-projects">
                <div class="start-app-icon">
                    <FolderKanban size={22} />
                </div>
                <span>Proyectos</span>
            </button>
            <button class="start-app-item" data-target="window-contact">
                <div class="start-app-icon">
                    <Mail size={22} />
                </div>
                <span>Contacto</span>
            </button>
            <button class="start-app-item" data-target="window-terminal">
                <div class="start-app-icon">
                    <SquareTerminal size={22} />
                </div>
                <span>Terminal</span>
            </button>
        </div>
    </div>

    <div class="start-footer">
        <div class="start-user">
            <div class="start-user-avatar">AH</div>
            <div class="start-user-info">
                <span class="start-user-name">Alfonso Hernández</span>
                <span class="start-user-alias">@madara</span>
            </div>
        </div>
        <button class="start-power" aria-label="Apagar">
            <Power size={16} />
        </button>
    </div>
</div>
