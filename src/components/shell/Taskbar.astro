---
import { User, FolderKanban, Mail } from "@lucide/astro";
---

<footer class="taskbar" aria-label="Barra de tareas">
    <button class="taskbar-start" type="button" id="start-btn" aria-label="Inicio">
        ⌘
    </button>

    <nav class="taskbar-apps" aria-label="Aplicaciones abiertas">
        <button type="button" class="taskbar-app" data-target="window-about">
            <User size={20} />
            <span class="taskbar-app-dot"></span>
        </button>
        <button type="button" class="taskbar-app" data-target="window-projects">
            <FolderKanban size={20} />
            <span class="taskbar-app-dot"></span>
        </button>
        <button type="button" class="taskbar-app" data-target="window-contact">
            <Mail size={20} />
            <span class="taskbar-app-dot"></span>
        </button>
    </nav>

    <div class="system-tray">
        <span>ES</span>
        <span id="system-clock">00:00</span>
    </div>
</footer>

<script>
    function updateClock() {
        const clock = document.getElementById("system-clock");
        if (!clock) return;
        const now = new Date();
        const h = now.getHours().toString().padStart(2, "0");
        const m = now.getMinutes().toString().padStart(2, "0");
        clock.textContent = `${h}:${m}`;
    }
    updateClock();
    setInterval(updateClock, 1000);
</script>
