---
---

<div class="snake-app">
    <div class="snake-hud">
        <div class="snake-hud-item">
            <span class="snake-hud-label">Score</span>
            <span class="snake-hud-value" id="snake-score">0</span>
        </div>
        <div class="snake-hud-item">
            <span class="snake-hud-label">Best</span>
            <span class="snake-hud-value" id="snake-hiscore">0</span>
        </div>
        <div class="snake-hud-item">
            <span class="snake-hud-label">Level</span>
            <span class="snake-hud-value" id="snake-level">1</span>
        </div>
    </div>

    <div class="snake-arena" id="snake-arena">
        <canvas id="snake-canvas"></canvas>
        <div id="snake-overlay" class="snake-overlay">
            <p class="snake-overlay-title">&gt;SNAKE_</p>
            <p class="snake-overlay-sub">Use ↑↓←→ or WASD to move</p>
            <button id="snake-btn" class="snake-btn">Iniciar</button>
        </div>
    </div>

    <div class="snake-controls-hint">
        <span>↑↓←→ / WASD · mover</span>
        <span>P · pausar</span>
    </div>
</div>

<style>
.snake-app {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    height: 100%;
    width: 100%;
    user-select: none;
    min-height: 0;
}

.snake-hud {
    display: flex;
    gap: 2.5rem;
    font-family: var(--font-mono);
    flex-shrink: 0;
}

.snake-hud-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
}

.snake-hud-label {
    font-size: 0.6rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
}

.snake-hud-value {
    font-size: 1.6rem;
    font-weight: 700;
    color: #3ecf8e;
    min-width: 3ch;
    text-align: center;
}

.snake-arena {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(62, 207, 142, 0.2);
    box-shadow:
        0 0 0 1px rgba(62, 207, 142, 0.08),
        0 0 60px rgba(62, 207, 142, 0.08),
        inset 0 0 80px rgba(0, 0, 0, 0.5);
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
}

#snake-canvas {
    display: block;
    background: #0a0a0c;
}

.snake-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    background: rgba(10, 10, 12, 0.86);
    backdrop-filter: blur(8px);
    border-radius: inherit;
    transition: opacity 0.2s ease;
}

.snake-overlay.hidden {
    opacity: 0;
    pointer-events: none;
}

.snake-overlay-title {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: #3ecf8e;
    letter-spacing: 0.1em;
    text-shadow: 0 0 32px rgba(62, 207, 142, 0.6);
}

.snake-overlay-sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
}

.snake-overlay-score {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: rgba(242, 242, 247, 0.75);
    text-align: center;
}

.snake-btn {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #0a0a0c;
    background: #3ecf8e;
    border: none;
    border-radius: 6px;
    padding: 0.6rem 2rem;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 0 0 24px rgba(62, 207, 142, 0.4);
    margin-top: 0.25rem;
}

.snake-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 36px rgba(62, 207, 142, 0.6);
}

.snake-controls-hint {
    display: flex;
    gap: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted);
    opacity: 0.55;
    flex-shrink: 0;
}
</style>

<script>
    const canvas = document.getElementById("snake-canvas") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d")!;
    const arena = document.getElementById("snake-arena")!;
    const overlay = document.getElementById("snake-overlay")!;
    const btn = document.getElementById("snake-btn") as HTMLButtonElement;
    const scoreEl = document.getElementById("snake-score")!;
    const hiscoreEl = document.getElementById("snake-hiscore")!;
    const levelEl = document.getElementById("snake-level")!;

    const COLS = 20;
    const ROWS = 20;
    const PALETTE = {
        bg: "#0a0a0c",
        grid: "rgba(255,255,255,0.028)",
        snake: "#3ecf8e",
        snakeHead: "#5ffba8",
        food: "#ff5f5f",
        foodGlow: "rgba(255,95,95,0.4)",
    };

    let cellSize = 20;
    let snake: { x: number; y: number }[] = [];
    let dir = { x: 1, y: 0 };
    let nextDir = { x: 1, y: 0 };
    let food = { x: 0, y: 0 };
    let score = 0;
    let hiscore = Number(localStorage.getItem("snake:hi") ?? 0);
    let level = 1;
    let running = false;
    let paused = false;
    let loopId = 0;
    let lastTime = 0;
    let elapsed = 0;

    function getSpeed() {
        return Math.max(80, 220 - (level - 1) * 18);
    }

    function resize() {
        const w = arena.clientWidth;
        const h = arena.clientHeight;
        // Size must be an exact multiple of COLS so no fractional leftover strip
        cellSize = Math.max(4, Math.floor(Math.min(w, h) / COLS));
        const size = cellSize * COLS;
        canvas.width = size;
        canvas.height = size;
        if (running && !paused) draw();
        else drawIdle();
    }

    function drawIdle() {
        const s = canvas.width;
        ctx.fillStyle = PALETTE.bg;
        ctx.fillRect(0, 0, s, s);
        drawGrid();
    }

    function drawGrid() {
        const total = COLS * cellSize;
        ctx.strokeStyle = PALETTE.grid;
        ctx.lineWidth = 0.5;
        for (let r = 0; r <= ROWS; r++) {
            ctx.beginPath();
            ctx.moveTo(0, r * cellSize);
            ctx.lineTo(total, r * cellSize);
            ctx.stroke();
        }
        for (let c = 0; c <= COLS; c++) {
            ctx.beginPath();
            ctx.moveTo(c * cellSize, 0);
            ctx.lineTo(c * cellSize, total);
            ctx.stroke();
        }
    }

    function spawnFood() {
        const occupied = new Set(snake.map(s => `${s.x},${s.y}`));
        let fx: number, fy: number;
        do {
            fx = Math.floor(Math.random() * COLS);
            fy = Math.floor(Math.random() * ROWS);
        } while (occupied.has(`${fx},${fy}`));
        food = { x: fx, y: fy };
    }

    function draw() {
        const total = COLS * cellSize;
        ctx.save();
        ctx.beginPath();
        ctx.rect(0, 0, total, total);
        ctx.clip();
        ctx.fillStyle = PALETTE.bg;
        ctx.fillRect(0, 0, total, total);
        drawGrid();

        // Food glow
        const fx = food.x * cellSize + cellSize / 2;
        const fy = food.y * cellSize + cellSize / 2;
        const grd = ctx.createRadialGradient(fx, fy, 0, fx, fy, cellSize * 1.6);
        grd.addColorStop(0, PALETTE.foodGlow);
        grd.addColorStop(1, "transparent");
        ctx.fillStyle = grd;
        ctx.fillRect(food.x * cellSize - cellSize, food.y * cellSize - cellSize, cellSize * 3, cellSize * 3);

        // Food
        ctx.fillStyle = PALETTE.food;
        ctx.shadowColor = PALETTE.food;
        ctx.shadowBlur = cellSize * 0.4;
        ctx.beginPath();
        const pr = cellSize * 0.35;
        ctx.roundRect(food.x * cellSize + cellSize * 0.12, food.y * cellSize + cellSize * 0.12, cellSize * 0.76, cellSize * 0.76, pr);
        ctx.fill();
        ctx.shadowBlur = 0;

        // Snake body
        for (let i = snake.length - 1; i >= 0; i--) {
            const seg = snake[i];
            const t = i / Math.max(snake.length, 1);
            ctx.globalAlpha = 0.45 + 0.55 * (1 - t);
            ctx.fillStyle = i === 0 ? PALETTE.snakeHead : PALETTE.snake;
            const pad = i === 0 ? 1 : 2;
            const rad = cellSize * (i === 0 ? 0.3 : 0.22);
            ctx.beginPath();
            ctx.roundRect(seg.x * cellSize + pad, seg.y * cellSize + pad, cellSize - pad * 2, cellSize - pad * 2, rad);
            ctx.fill();
        }
        ctx.globalAlpha = 1;

        // Eyes on head
        if (snake.length > 0) {
            const head = snake[0];
            const ex = head.x * cellSize + cellSize / 2;
            const ey = head.y * cellSize + cellSize / 2;
            const eyeOff = cellSize * 0.18;
            const perpX = -dir.y * eyeOff;
            const perpY = dir.x * eyeOff;
            ctx.fillStyle = "#0a0a0c";
            [1, -1].forEach(sign => {
                ctx.beginPath();
                ctx.arc(ex + perpX * sign + dir.x * eyeOff, ey + perpY * sign + dir.y * eyeOff, cellSize * 0.09, 0, Math.PI * 2);
                ctx.fill();
            });
        }
        ctx.restore();
    }

    function tick() {
        dir = { ...nextDir };
        const head = { x: (snake[0].x + dir.x + COLS) % COLS, y: (snake[0].y + dir.y + ROWS) % ROWS };

        if (snake.some(s => s.x === head.x && s.y === head.y)) {
            gameOver();
            return;
        }

        snake.unshift(head);

        if (head.x === food.x && head.y === food.y) {
            score++;
            level = Math.floor(score / 5) + 1;
            scoreEl.textContent = String(score);
            levelEl.textContent = String(level);
            if (score > hiscore) {
                hiscore = score;
                localStorage.setItem("snake:hi", String(hiscore));
                hiscoreEl.textContent = String(hiscore);
            }
            spawnFood();
        } else {
            snake.pop();
        }

        draw();
    }

    function loop(ts: number) {
        if (!running || paused) return;
        const dt = ts - lastTime;
        elapsed += dt;
        lastTime = ts;
        if (elapsed >= getSpeed()) {
            elapsed = 0;
            tick();
        }
        loopId = requestAnimationFrame(loop);
    }

    function startGame() {
        snake = [
            { x: 10, y: 10 }, { x: 9, y: 10 }, { x: 8, y: 10 },
        ];
        dir = { x: 1, y: 0 };
        nextDir = { x: 1, y: 0 };
        score = 0;
        level = 1;
        scoreEl.textContent = "0";
        levelEl.textContent = "1";
        hiscoreEl.textContent = String(hiscore);
        spawnFood();
        running = true;
        paused = false;
        overlay.classList.add("hidden");
        cancelAnimationFrame(loopId);
        lastTime = performance.now();
        elapsed = 0;
        loopId = requestAnimationFrame(loop);
    }

    function gameOver() {
        running = false;
        cancelAnimationFrame(loopId);
        const sub = overlay.querySelector(".snake-overlay-sub")!;
        overlay.querySelector(".snake-overlay-score")?.remove();

        const scoreP = document.createElement("p");
        scoreP.className = "snake-overlay-score";
        scoreP.textContent = `Puntuación: ${score}${score > 0 && score === hiscore ? " 🏆 ¡Nuevo récord!" : ""}`;
        sub.insertAdjacentElement("afterend", scoreP);
        sub.textContent = "Use ↑↓←→ or WASD to move";

        btn.textContent = "Reintentar";
        overlay.classList.remove("hidden");
    }

    function togglePause() {
        if (!running) return;
        paused = !paused;
        if (!paused) {
            lastTime = performance.now();
            elapsed = 0;
            loopId = requestAnimationFrame(loop);
        }
    }

    const keyMap: Record<string, { x: number; y: number }> = {
        ArrowUp: { x: 0, y: -1 }, w: { x: 0, y: -1 }, W: { x: 0, y: -1 },
        ArrowDown: { x: 0, y: 1 }, s: { x: 0, y: 1 }, S: { x: 0, y: 1 },
        ArrowLeft: { x: -1, y: 0 }, a: { x: -1, y: 0 }, A: { x: -1, y: 0 },
        ArrowRight: { x: 1, y: 0 }, d: { x: 1, y: 0 }, D: { x: 1, y: 0 },
    };

    document.addEventListener("keydown", (e) => {
        if (!document.getElementById("window-snake")?.classList.contains("active")) return;
        if (e.key === "p" || e.key === "P") { togglePause(); return; }
        const newDir = keyMap[e.key];
        if (!newDir) return;
        if (newDir.x === -dir.x && newDir.y === -dir.y) return;
        nextDir = newDir;
        if (e.key.startsWith("Arrow")) e.preventDefault();
    });

    // Touch swipe
    let touchStart = { x: 0, y: 0 };
    canvas.addEventListener("touchstart", e => {
        touchStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
    }, { passive: true });
    canvas.addEventListener("touchend", e => {
        const dx = e.changedTouches[0].clientX - touchStart.x;
        const dy = e.changedTouches[0].clientY - touchStart.y;
        if (Math.abs(dx) < 10 && Math.abs(dy) < 10) return;
        let newDir: { x: number; y: number };
        if (Math.abs(dx) > Math.abs(dy)) {
            newDir = dx > 0 ? { x: 1, y: 0 } : { x: -1, y: 0 };
        } else {
            newDir = dy > 0 ? { x: 0, y: 1 } : { x: 0, y: -1 };
        }
        if (newDir.x === -dir.x && newDir.y === -dir.y) return;
        nextDir = newDir;
    }, { passive: true });

    btn.addEventListener("click", startGame);

    const ro = new ResizeObserver(resize);
    ro.observe(arena);
    resize();
    hiscoreEl.textContent = String(hiscore);
</script>
