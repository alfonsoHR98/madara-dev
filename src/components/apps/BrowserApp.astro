<div class="browser-app">
    <div class="browser-toolbar">
        <button class="browser-nav-btn" id="browser-back" title="Atrás">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        </button>
        <button class="browser-nav-btn" id="browser-forward" title="Adelante">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
        <button class="browser-nav-btn" id="browser-home-btn" title="Inicio">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </button>
        <button class="browser-nav-btn" id="browser-refresh" title="Recargar">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        </button>
        <div class="browser-url-wrap">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <input type="text" id="browser-url-input" placeholder="Escribe una URL y presiona Enter..." />
        </div>
    </div>

    <div class="browser-home" id="browser-home">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <p>Nueva pestaña</p>
        <span>Escribe una URL arriba o elige un acceso rápido</span>
        <div class="browser-suggestions">
            <button data-url="https://github.com/alfonsoHR98">Mi GitHub</button>
            <button data-url="https://developer.mozilla.org/es">MDN Docs</button>
            <button data-url="https://astro.build/docs">Astro Docs</button>
            <button data-url="https://supabase.com/docs">Supabase</button>
        </div>
    </div>

    <iframe id="browser-frame" class="browser-frame" style="display:none"></iframe>
</div>

<script>
    const frame = document.getElementById("browser-frame") as HTMLIFrameElement;
    const input = document.getElementById("browser-url-input") as HTMLInputElement;
    const home = document.getElementById("browser-home") as HTMLElement;
    const backBtn = document.getElementById("browser-back");
    const forwardBtn = document.getElementById("browser-forward");
    const refreshBtn = document.getElementById("browser-refresh");

    function navigate(url: string) {
        let full = url.trim();
        if (!full.startsWith("http://") && !full.startsWith("https://")) {
            full = "https://" + full;
        }
        input.value = full;
        home.style.display = "none";
        frame.style.display = "block";
        frame.src = full;
    }

    input.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && input.value.trim()) navigate(input.value);
    });

    const homeBtn = document.getElementById("browser-home-btn");
    homeBtn?.addEventListener("click", () => {
        frame.style.display = "none";
        frame.src = "";
        input.value = "";
        home.style.display = "flex";
    });

    refreshBtn?.addEventListener("click", () => {
        if (frame.src) { frame.src = frame.src; }
    });
    backBtn?.addEventListener("click", () => { frame.contentWindow?.history.back(); });
    forwardBtn?.addEventListener("click", () => { frame.contentWindow?.history.forward(); });

    document.querySelectorAll<HTMLButtonElement>(".browser-suggestions button").forEach(btn => {
        btn.addEventListener("click", () => {
            const url = btn.dataset.url;
            if (url) navigate(url);
        });
    });
</script>
