---
import data from "../../data/resume.json";

const { personalInfo, experience, projects, skills, education, languages } = data;
const featuredProjects = projects.slice(0, 3);
---

<section class="resume-root resume-root--hero">
    <div class="resume-hero-grid">
        <div class="about-avatar">
            {personalInfo.avatarUrl ? (
                <img src={personalInfo.avatarUrl} alt={personalInfo.name} width="96" height="96" loading="lazy" decoding="async" />
            ) : (
                <div class="avatar-initials">{personalInfo.initials}</div>
            )}
        </div>

        <div class="resume-header-info">
            <p class="app-label">Perfil</p>
            <h2 class="resume-name">{personalInfo.name}</h2>
            <p class="about-alias">{personalInfo.alias} · {personalInfo.title}</p>
            <p class="about-bio">{personalInfo.summary}</p>

            <div class="resume-meta">
                <span>{personalInfo.location}</span>
                <span>{personalInfo.email}</span>
            </div>

            <div class="resume-socials">
                <a href={personalInfo.github} target="_blank" rel="noopener noreferrer" class="resume-social-btn">GitHub</a>
                <a href={personalInfo.linkedin} target="_blank" rel="noopener noreferrer" class="resume-social-btn">LinkedIn</a>
                <button type="button" class="resume-social-btn resume-social-btn--primary" onclick="window.print()">Descargar CV</button>
            </div>
        </div>

        <aside class="resume-signal-card" aria-label="Resumen rápido">
            <span class="resume-signal-kicker">Disponible para</span>
            <strong>Interfaces inmersivas, automatización y producto web</strong>
            <span class="resume-signal-status">● Online desde México</span>
        </aside>
    </div>

    <div class="resume-separator"></div>

    <div class="resume-section resume-section--featured">
        <h3 class="resume-section-title">Experiencia reciente</h3>
        <div class="resume-timeline">
            {experience.map((job) => (
                <article class="resume-exp-item">
                    <div class="resume-exp-header">
                        <div>
                            <h4 class="resume-exp-role">{job.role}</h4>
                            <p class="resume-exp-company">{job.company}</p>
                            <p class="resume-exp-location">{job.location}</p>
                        </div>
                        <span class="resume-badge">{job.period}</span>
                    </div>
                    <ul class="resume-exp-achievements">
                        {job.achievements.map((achievement) => <li><span>•</span>{achievement}</li>)}
                    </ul>
                </article>
            ))}
        </div>
    </div>

    <div class="resume-separator"></div>

    <div class="resume-section">
        <h3 class="resume-section-title">Proyectos destacados</h3>
        <div class="resume-projects-grid">
            {featuredProjects.map((project) => {
                const hasUrl = Boolean(project.url && project.url !== "#");
                const Tag = hasUrl ? "a" : "div";
                return (
                    <Tag
                        href={hasUrl ? project.url : undefined}
                        target={hasUrl ? "_blank" : undefined}
                        rel={hasUrl ? "noopener noreferrer" : undefined}
                        class="resume-project-card"
                    >
                        <div class="resume-project-top">
                            <h4>{project.name}</h4>
                            {hasUrl && <span>↗</span>}
                        </div>
                        <p>{project.desc}</p>
                        <div class="resume-project-stack">
                            {project.tech.map((tech) => <span class="resume-tag">{tech}</span>)}
                        </div>
                    </Tag>
                );
            })}
        </div>
    </div>

    <div class="resume-separator"></div>

    <div class="resume-section">
        <h3 class="resume-section-title">Stack</h3>
        <div class="resume-skills-list">
            {skills.map((group) => (
                <div class="resume-skill-group">
                    <p class="resume-skill-category">{group.category}</p>
                    <div class="skills-grid">
                        {group.items.map((skill) => <span class="skill-tag">{skill}</span>)}
                    </div>
                </div>
            ))}
        </div>
    </div>

    <div class="resume-separator"></div>

    <div class="resume-bottom-grid">
        <div class="resume-section">
            <h3 class="resume-section-title">Educación</h3>
            <div class="resume-education-list">
                {education.map((edu) => (
                    <article class="resume-edu-item">
                        <div class="resume-edu-header">
                            <div>
                                <h4 class="resume-edu-degree">{edu.degree}</h4>
                                <p class="resume-edu-institution">{edu.institution}</p>
                            </div>
                            <span class="resume-muted-text">{edu.period}</span>
                        </div>
                        {edu.extra && <span class="resume-badge resume-badge--outline">{edu.extra}</span>}
                    </article>
                ))}
            </div>
        </div>

        <div class="resume-section">
            <h3 class="resume-section-title">Idiomas</h3>
            <div class="resume-languages-grid">
                {languages.map((language) => (
                    <div class="resume-lang-item">
                        <div class="resume-lang-header">
                            <span>{language.lang}</span>
                            <span class="resume-muted-text">{language.level}</span>
                        </div>
                        <div class="resume-lang-track">
                            <div class="resume-lang-bar" style={`width: ${language.percentage}%`}></div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>

    <div class="app-actions resume-actions">
        <button type="button" data-target="window-projects">Ver proyectos</button>
        <button type="button" data-target="window-contact">Contacto</button>
    </div>
</section>
