---
const links = [
    {
        label: "GitHub",
        handle: "@alfonsoHR98",
        url: "https://github.com/alfonsoHR98",
        icon: "⌥",
    },
    {
        label: "Email",
        handle: "alfonsohr_98@outlook.com",
        url: "mailto:alfonsohr_98@outlook.com",
        icon: "✉",
    },
    {
        label: "LinkedIn",
        handle: "tu-usuario",
        url: "https://linkedin.com/in/tu-usuario",
        icon: "⬡",
    },
];
---

<section class="contact-panel">
    <p class="app-label">Contacto</p>
    <h1>Hablemos</h1>
    <p class="contact-description">
        ¿Tienes un proyecto en mente o quieres colaborar? Escríbeme.
    </p>

    <div class="contact-links">
        {
            links.map((l) => (
                <a
                    href={l.url}
                    class="contact-card"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <span class="contact-icon">{l.icon}</span>
                    <div class="contact-info">
                        <span class="contact-label">{l.label}</span>
                        <span class="contact-handle">{l.handle}</span>
                    </div>
                </a>
            ))
        }
    </div>
</section>
