---
import { Mail } from "@lucide/astro";
import data from "../../data/resume.json";

const { personalInfo } = data;
const githubHandle = personalInfo.github.replace(/^https?:\/\/github.com\//, "@");
const linkedinHandle = personalInfo.linkedin.replace(/^https?:\/\/linkedin.com\/in\//, "").replace(/\/$/, "");
---

<section class="contact-panel">
    <div class="contact-hero">
        <p class="app-label">Contacto</p>
        <h1>Hablemos de tu siguiente build</h1>
        <p class="contact-description">
            Si tienes una idea, automatización o interfaz que quieres convertir en producto, mándame el contexto y te respondo directo.
        </p>
        <div class="contact-status">
            <span></span>
            Disponible para proyectos seleccionados
        </div>
    </div>

    <div class="contact-grid">
        <form class="contact-form" data-contact-form data-recipient={personalInfo.email}>
            <div class="contact-field-row">
                <label>
                    <span>Nombre</span>
                    <input name="name" type="text" autocomplete="name" placeholder="Tu nombre" required />
                </label>
                <label>
                    <span>Email</span>
                    <input name="email" type="email" autocomplete="email" placeholder="tu@email.com" required />
                </label>
            </div>

            <label>
                <span>Tipo de proyecto</span>
                <select name="projectType" required>
                    <option value="Web app">Web app</option>
                    <option value="Portfolio / landing">Portfolio / landing</option>
                    <option value="Automatización">Automatización</option>
                    <option value="Consultoría">Consultoría</option>
                </select>
            </label>

            <label>
                <span>Mensaje</span>
                <textarea name="message" rows="5" placeholder="Cuéntame qué quieres construir, tiempos, presupuesto aproximado o links útiles." required></textarea>
            </label>

            <button type="submit">Preparar mensaje</button>
            <p class="contact-form-note">Por ahora abre tu cliente de correo. Recomendado: conectar Resend cuando despliegues con serverless.</p>
        </form>

        <div class="contact-side">
            <a href={`mailto:${personalInfo.email}`} class="contact-card contact-card--primary" target="_blank" rel="noopener noreferrer">
                <span class="contact-icon"><Mail size={18} /></span>
                <div class="contact-info">
                    <span class="contact-label">Email directo</span>
                    <span class="contact-handle">{personalInfo.email}</span>
                </div>
            </a>

            <a href={personalInfo.github} class="contact-card" target="_blank" rel="noopener noreferrer">
                <span class="contact-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"></path>
                    </svg>
                </span>
                <div class="contact-info">
                    <span class="contact-label">GitHub</span>
                    <span class="contact-handle">{githubHandle}</span>
                </div>
            </a>

            <a href={personalInfo.linkedin} class="contact-card" target="_blank" rel="noopener noreferrer">
                <span class="contact-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
                    </svg>
                </span>
                <div class="contact-info">
                    <span class="contact-label">LinkedIn</span>
                    <span class="contact-handle">{linkedinHandle}</span>
                </div>
            </a>

            <div class="contact-service-note">
                <span>Recomendación</span>
                <strong>Resend + dominio verificado</strong>
                <p>Ideal para formulario profesional si el sitio corre con Vercel/Netlify/adapter serverless.</p>
            </div>
        </div>
    </div>
</section>

<script>
    document.querySelector<HTMLFormElement>("[data-contact-form]")?.addEventListener("submit", (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        const formData = new FormData(form);
        const recipient = form.dataset.recipient ?? "";
        const name = String(formData.get("name") ?? "");
        const email = String(formData.get("email") ?? "");
        const projectType = String(formData.get("projectType") ?? "");
        const message = String(formData.get("message") ?? "");
        const subject = encodeURIComponent(`Nuevo proyecto: ${projectType}`);
        const body = encodeURIComponent(`Nombre: ${name}\nEmail: ${email}\nTipo: ${projectType}\n\nMensaje:\n${message}`);
        window.location.href = `mailto:${recipient}?subject=${subject}&body=${body}`;
    });
</script>
