---
import data from "../../data/resume.json";

const fallbackColors = ["#4f9eff", "#ea4b71", "#3ecf8e", "#ff9900"];
const projects = data.projects.map((project, index) => ({
    ...project,
    color: project.color ?? fallbackColors[index % fallbackColors.length],
    featured: index === 0,
    hasUrl: Boolean(project.url && project.url !== "#"),
}));
const featured = projects.find((project) => project.featured);
const rest = projects.filter((project) => !project.featured);
---

<section class="projects-panel">
    <div class="projects-header">
        <div>
            <p class="app-label">Proyectos</p>
            <h2>Mi trabajo</h2>
        </div>
        <span class="projects-count">{projects.length} builds activos</span>
    </div>

    {featured && (
        <article class="project-card project-featured" style={`--card-color: ${featured.color}`}>
            <div class="project-orb" aria-hidden="true"></div>
            <div class="featured-badge">Destacado</div>
            <div class="project-featured-body">
                <h3>{featured.name}</h3>
                <p>{featured.desc}</p>
                <div class="project-stack">
                    {featured.tech.map((tech) => <span class="tag">{tech}</span>)}
                </div>
            </div>
            <div class="project-links">
                {featured.hasUrl ? (
                    <a href={featured.url} target="_blank" rel="noopener noreferrer">Ver sitio</a>
                ) : (
                    <span class="project-link-soon">Próximamente</span>
                )}
            </div>
        </article>
    )}

    <div class="projects-grid">
        {rest.map(p => (
            <article class="project-card" style={`--card-color: ${p.color}`}>
                <span class="project-index">0{projects.indexOf(p) + 1}</span>
                <div class="project-info">
                    <h3>{p.name}</h3>
                    <p>{p.desc}</p>
                    <div class="project-stack">
                        {p.tech.map((tech) => <span class="tag">{tech}</span>)}
                    </div>
                </div>
                <div class="project-links">
                    {p.hasUrl ? (
                        <a href={p.url} target="_blank" rel="noopener noreferrer">Ver sitio</a>
                    ) : (
                        <span class="project-link-soon">Próximamente</span>
                    )}
                </div>
            </article>
        ))}
    </div>
</section>
