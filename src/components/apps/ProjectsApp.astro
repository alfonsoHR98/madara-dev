---
import data from "../../data/resume.json";

const colors = ["#4f9eff", "#ea4b71", "#3ecf8e", "#ff9900"];
const projects = data.projects.map((project, index) => ({
    ...project,
    color: colors[index % colors.length],
    featured: index === 0,
}));
const featured = projects.find((project) => project.featured);
const rest = projects.filter((project) => !project.featured);
---

<section class="projects-panel">
    <p class="app-label">Proyectos</p>
    <h1>Mi trabajo</h1>

    {featured && (
        <article class="project-card project-featured" style={`--card-color: ${featured.color}`}>
            <div class="featured-badge">Destacado</div>
            <h2>{featured.name}</h2>
            <p>{featured.desc}</p>
            <div class="project-stack">
                {featured.tech.map((tech) => <span class="tag">{tech}</span>)}
            </div>
            <div class="project-links">
                <a href={featured.url}>Ver sitio</a>
            </div>
        </article>
    )}

    <div class="projects-grid">
        {rest.map(p => (
            <article class="project-card" style={`--card-color: ${p.color}`}>
                <div class="project-info">
                    <h2>{p.name}</h2>
                    <p>{p.desc}</p>
                    <div class="project-stack">
                        {p.tech.map((tech) => <span class="tag">{tech}</span>)}
                    </div>
                </div>
                <div class="project-links">
                    <a href={p.url}>Ver sitio</a>
                </div>
            </article>
        ))}
    </div>
</section>
